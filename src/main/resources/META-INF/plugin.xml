<idea-plugin>
    <id>com.codearena.codearena-plugin</id>
    <name>CodeArena</name>
    <version>1.0.0</version>
    <vendor email="support@codearena.dev">CodeArena</vendor>

    <description>
        Transform errors into micro-learning challenges.
    </description>

    <!-- CHANGE THIS: Use 233 to match your IntelliJ version -->
    <idea-version since-build="231"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <actions>
        <action id="CodeArena.TestAction"
                class="com.codearena.actions.TestAction"
                text="Configure CodeArena AI"
                description="Configure OpenAI API key and AI settings">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </action>
        <action id="CodeArena.TriggerChallenge"
                class="com.codearena.actions.TriggerChallengeAction"
                text="Generate Debug Challenge"
                description="Manually trigger a debugging challenge based on current intent">
            <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="CodeArena.TestAction"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift D"/>
        </action>
    </actions>


    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="CodeArena" displayType="BALLOON" />
        <!-- Tool Window Registration -->
        <toolWindow id="CodeArena Intent Pad"
                    anchor="right"
                    factoryClass="com.codearena.ui.IntentPadToolWindowFactory"
                    icon="AllIcons.Actions.IntentionBulb"/>

        <!-- Startup Activity -->
        <backgroundPostStartupActivity
                implementation="com.codearena.core.CodeArenaStartup"/>
        <applicationService serviceImplementation="com.codearena.persistence.SettingsManager"/>
    </extensions>


    <!-- Rest of your plugin.xml -->
</idea-plugin>